# ============================================================================
#  ENVIRONMENT VARIABLES — copy this file to ".env" and fill in real values.
#  NEVER commit the real .env. All secrets are read from these variables only;
#  there are NO hardcoded keys anywhere in the source code.
# ============================================================================

# ---- Supabase (the ONLY backend service) ----------------------------------
# Public values (safe to expose to the browser; injected at build time).
VITE_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR-SUPABASE-ANON-KEY"
VITE_SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-side mirrors of the public values (used during SSR / server routes).
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_PUBLISHABLE_KEY="YOUR-SUPABASE-ANON-KEY"
SUPABASE_PROJECT_ID="YOUR-PROJECT-REF"

# Server-ONLY secret. Bypasses Row Level Security. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SUPABASE-SERVICE-ROLE-KEY"

# ---- Stripe (subscriptions / checkout) ------------------------------------
# Server-ONLY secret key (Dashboard → Developers → API keys). Use sk_test_…
# while testing, sk_live_… in production. NEVER expose to the client.
STRIPE_SECRET_KEY="sk_test_YOUR-STRIPE-SECRET-KEY"
# Webhook signing secret (Dashboard → Developers → Webhooks → your endpoint).
# Endpoint URL: https://YOUR-DOMAIN/api/public/stripe-webhook
# Subscribe to event: checkout.session.completed
STRIPE_WEBHOOK_SECRET="whsec_YOUR-WEBHOOK-SIGNING-SECRET"
# Recurring Price IDs for each weekly plan (Dashboard → Product catalog).
# Each must be a recurring price billed every week. The 3-day free trial for
# the Starter plan is applied automatically in checkout (no Stripe config).
STRIPE_PRICE_STARTER="price_YOUR-STARTER-19_99-WEEKLY"
STRIPE_PRICE_ASSISTANT="price_YOUR-ASSISTANT-29_99-WEEKLY"
STRIPE_PRICE_PRO="price_YOUR-PRO-49_99-WEEKLY"

# ---- Telegram bot (independent notification module) -----------------------
# From @BotFather. Used server-side only to send event notifications.
TELEGRAM_BOT_TOKEN="123456:ABC-YOUR-BOT-TOKEN"
# The chat/channel/group ID that should receive notifications.
TELEGRAM_CHAT_ID="-1001234567890"

# ---- Visitor stats / weekly report ----------------------------------------
# Shared secret protecting the analytics report endpoints so only your
# scheduler (pg_cron / Vercel Cron) — not the public — can trigger them:
#   /api/public/stats          (today / 7d / 30d / all-time visitor report)
#   /api/public/weekly-report  (last-7-days summary)
# Generate any long random string, e.g.:  openssl rand -hex 32
WEEKLY_REPORT_SECRET="YOUR-LONG-RANDOM-SECRET"

# Telegram notification on each website visit (handled in /api/public/track):
#   "new" → notify only on first-time (new) visitors  (recommended)
#   "all" → notify on EVERY page hit                  (very noisy on real traffic)
#   "off" → disabled (default)
NOTIFY_VISIT="off"

# ---- Deployment target (build-time) ---------------------------------------
# vercel | netlify | node-server (VPS/Docker/Railway/Render) | cloudflare-module
# Vercel reads this from vercel.json, Netlify from netlify.toml.
# For a plain Node/Docker build leave it as node-server (the default).
NITRO_PRESET="node-server"
